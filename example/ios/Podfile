ENV['RCT_USE_RN_DEP'] = '1'
ENV['RCT_NEW_ARCH_ENABLED'] = '1'

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'TurboDBExample' do
  project 'TurboDBExample.xcodeproj'
  config = use_native_modules!

  # TurboDB native module
  pod 'TurboDB', :path => '../..'

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )

    # Workaround: Xcode 26 Beta + RN 0.85 — Folly's Expected.h tries to include
    # folly/coro/Coroutine.h which does not exist in the iOS 26 SDK.
    # FOLLY_CFG_NO_COROUTINES is the correct pre-detection guard in Portability.h.
    # It must be set before compiler feature detection fires (unlike FOLLY_HAS_COROUTINES).
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        # Ensure libsodium headers are prioritized everywhere to avoid utils.h collision
        header_paths = config.build_settings['HEADER_SEARCH_PATHS'] || '$(inherited)'
        unless header_paths.include?('src/libsodium/include/sodium')
          config.build_settings['HEADER_SEARCH_PATHS'] = "\"$(PODS_ROOT)/libsodium/src/libsodium/include/sodium\" #{header_paths}"
        end

        # Remove React-VFS overlay which causes header collisions (utils.h)
        ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS', 'OTHER_SWIFT_FLAGS'].each do |key|
          settings = config.build_settings[key]
          if settings.is_a?(String)
            # Handle both quoted and unquoted paths, and both -ivfsoverlay and -Xcc -ivfsoverlay
            config.build_settings[key] = settings.gsub(/-ivfsoverlay\s+\"[^\"]*React-VFS\.yaml\"/, '')
                                               .gsub(/-ivfsoverlay\s+[^\s]*React-VFS\.yaml/, '')
                                               .gsub(/-Xcc\s+-ivfsoverlay\s+\"[^\"]*React-VFS\.yaml\"/, '')
                                               .gsub(/-Xcc\s+-ivfsoverlay\s+[^\s]*React-VFS\.yaml/, '')
          elsif settings.is_a?(Array)
            config.build_settings[key] = settings.reject { |s| s.include?('React-VFS.yaml') }
            # Also need to reject the flag itself if it's a separate element
            new_settings = []
            skip_next = false
            config.build_settings[key].each_with_index do |s, i|
              if skip_next
                skip_next = false
                next
              end
              if s == '-ivfsoverlay' || s == '-Xcc'
                # Check if next element contains React-VFS.yaml
                if config.build_settings[key][i+1] && config.build_settings[key][i+1].include?('React-VFS.yaml')
                  skip_next = true
                  next
                end
              end
              new_settings << s unless s.include?('React-VFS.yaml')
            end
            config.build_settings[key] = new_settings
          end
        end

        if target.name == 'libsodium'
          # Add alignment flags and ignore alignment errors
          ['OTHER_CFLAGS', 'OTHER_CPLUSPLUSFLAGS'].each do |key|
            flags = config.build_settings[key] || '$(inherited)'
            unless flags.include?('-DLS_ALIGNED_ONLY')
              config.build_settings[key] = "#{flags} -DLS_ALIGNED_ONLY -DLS_STRICT_ALIGNMENT -Wno-error=invalid-alignment"
            end
          end
        end
        flags = config.build_settings['OTHER_CPLUSPLUSFLAGS'] || '$(inherited)'
        unless flags.include?('FOLLY_CFG_NO_COROUTINES')
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = "#{flags} -DFOLLY_CFG_NO_COROUTINES"
        end
      end
    end
    libsodium_path = "Pods/libsodium/src/libsodium"
    if Dir.exist?(libsodium_path)
      # Ensure write permissions
      `chmod -R +w #{libsodium_path}`
      
      # 1. Fix alignment error in blake2b by adding padding
      blake2b_header = "Pods/libsodium/src/libsodium/include/sodium/crypto_generichash_blake2b.h"
      if File.exist?(blake2b_header)
        content = File.read(blake2b_header)
        unless content.include?('uint8_t  _padding[7];')
          new_content = content.gsub(/uint8_t\s+last_node;/, "uint8_t  last_node;\n    uint8_t  _padding[7];")
                               .gsub(/CRYPTO_ALIGN\(64\)/, 'CRYPTO_ALIGN(8)')
          File.write(blake2b_header, new_content)
        end
      end
    end

    # Direct fix for libsodium xcconfig files to remove React-VFS overlay
    ['debug', 'release'].each do |config|
      xcconfig_path = "Pods/Target Support Files/libsodium/libsodium.#{config}.xcconfig"
      if File.exist?(xcconfig_path)
        content = File.read(xcconfig_path)
        new_content = content.gsub(/-ivfsoverlay\s+\"[^\"]*React-VFS\.yaml\"/, '')
                             .gsub(/-ivfsoverlay\s+[^\s]*React-VFS\.yaml/, '')
        
        # Add alignment flags and ignore alignment errors
        unless new_content.include?('-DLS_ALIGNED_ONLY')
          if new_content =~ /OTHER_CFLAGS = \$\(inherited\)/
            new_content = new_content.gsub(/OTHER_CFLAGS = \$\(inherited\)/, 'OTHER_CFLAGS = $(inherited) -DLS_ALIGNED_ONLY -DLS_STRICT_ALIGNMENT -Wno-error=invalid-alignment -Wno-invalid-alignment')
          else
            new_content << "\nOTHER_CFLAGS = $(inherited) -DLS_ALIGNED_ONLY -DLS_STRICT_ALIGNMENT -Wno-error=invalid-alignment -Wno-invalid-alignment"
          end
        end
        
        File.write(xcconfig_path, new_content)
      end
    end
  end
end